# ============================================
# AMBIENTE PRODUÇÃO (Render, AWS, etc)
# ============================================
#
# INSTRUÇÕES:
# 1. Configure no painel do Render:
#    - Environment → Add Environment Variable
# 2. Ou crie um .env.production local baseado neste template
# 3. .env.production está no .gitignore, seus dados estão seguros
#
APP_ENV=production
DEBUG=false

# Credenciais do Google Cloud Vision
# OPÇÃO 1: JSON String Direto
#   - Copie o conteúdo de google-credentials.json
#   - Cole aqui entre as aspas
# OPÇÃO 2: Base64
#   - Encode: cat google-credentials.json | base64 -w 0
#   - Cole aqui entre as aspas
# OPÇÃO 3: Render Dashboard
#   - Deixe comentado e configure via interface do Render
#
# GOOGLE_CREDENTIALS_JSON='{"type":"service_account","project_id":"YOUR_PROJECT_ID","private_key":"-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n","client_email":"YOUR_SERVICE_ACCOUNT_EMAIL","client_id":"YOUR_CLIENT_ID","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"YOUR_CERT_URL"}'

GOOGLE_VISION_TIMEOUT_SECONDS=15
