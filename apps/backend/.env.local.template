# ============================================
# AMBIENTE LOCAL (Desenvolvimento)
# ============================================
# 
# INSTRUÇÕES:
# 1. Copie este arquivo para .env.local
# 2. Preencha os valores apropriados
# 3. .env.local está no .gitignore, seus dados estão seguros
#
APP_ENV=local
DEBUG=true

# Caminho para arquivo de credenciais JSON do Google Cloud
# Obtenha em: https://console.cloud.google.com/ -> Service Accounts
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json

GOOGLE_VISION_TIMEOUT_SECONDS=10
